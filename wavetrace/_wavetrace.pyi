class FeatureExtractor:
    def __init__(self, num_series: int, window: int, hop: int) -> None: ...
    @property
    def num_series(self) -> int: ...
    @property
    def window(self) -> int: ...
    @property
    def hop(self) -> int: ...
    @property
    def output_size(self) -> int: ...
    def reset(self) -> None: ...
    def push(self, values: npt.NDArray[np.float32]) -> bool:
        """Push one frame's num_series values; True when a feature vector was emitted."""
        ...
    @property
    def features(self) -> npt.NDArray[np.float32]:
        """Zero-copy view of the latest emitted vector (length 9*num_series, reused each emit)."""
        ...

class SpectrogramBuilder:
    def __init__(self, num_subcarriers: int, time_steps: int, hop: int) -> None: ...
    @property
    def num_subcarriers(self) -> int: ...
    @property
    def time_steps(self) -> int: ...
    @property
    def hop(self) -> int: ...
    def reset(self) -> None: ...
    def push(self, values: npt.NDArray[np.float32]) -> bool:
        """Push one frame's num_subcarriers values; True when an image was emitted."""
        ...
    @property
    def image(self) -> npt.NDArray[np.float32]:
        """Zero-copy view of the latest emitted (num_subcarriers x time_steps) image."""
        ...

