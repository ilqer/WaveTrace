class GainLock:
    def __init__(self, baseline_packets: int = 300) -> None: ...
    def observe(self, frame: CsiFrame) -> None: ...
    def finalize(self) -> None: ...
    def apply(self, frame: CsiFrame) -> None:
        """Rescale the frame's amplitudes to the locked reference, in place (phase preserved)."""
        ...
    @property
    def observed(self) -> int: ...
    @property
    def ready(self) -> bool: ...
    @property
    def locked(self) -> bool: ...
    @property
    def reference_scale(self) -> float: ...

class Preprocessor:
    def __init__(
