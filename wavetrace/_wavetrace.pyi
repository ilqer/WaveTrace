    def out_rows(self) -> int: ...
    @property
    def out_cols(self) -> int: ...
    def reset(self) -> None: ...
    def process(self, frame: CsiFrame) -> npt.NDArray[np.float32]:
        """One frame -> drift-free differential-phase grid (zero-copy view, same buffer each call)."""
