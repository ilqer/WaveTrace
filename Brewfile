# Brewfile — macOS system dependencies for WaveTrace
# Install all at once with:  brew bundle
#
# ffmpeg: local webcam capture for the web dashboard camera stream and
#         camera-supervised data collection.  The Python cv2.VideoCapture
#         segfaults on macOS when called from a background thread; ffmpeg
#         uses AVFoundation natively and handles the permission dialog itself.
brew "ffmpeg"
